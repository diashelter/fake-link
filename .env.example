# Compose
COMPOSE_PROJECT_NAME=fake_link
NGINX_HTTPS_PORT=443

# PostgreSQL
POSTGRES_USER=fake_link
POSTGRES_PASSWORD=change-me
POSTGRES_DB=fake_link

# Application
APP_KEY=base64:AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA=
APP_ENV=local
APP_DEBUG=true

# URLs
APP_URL=https://app.localhost
SHORT_HOST=go.localhost
NEXT_PUBLIC_APP_URL=https://app.localhost

# Redis
REDIS_HOST=redis-ephemeral
REDIS_PORT=6379
REDIS_QUEUE_HOST=redis-queue
REDIS_QUEUE_PORT=6379

# Dev publish ports (AD-004)
POSTGRES_PUBLISH_PORT=5432
REDIS_EPHEMERAL_PUBLISH_PORT=6379
REDIS_QUEUE_PUBLISH_PORT=6380
